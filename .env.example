# API publique Phase 1 (Render)
EXPO_PUBLIC_API_URL=https://amo-id-api.onrender.com

# Device seed trusté pour enrollment@amo-id.ml (voir seed API)
# Pour tester la révocation : seed-device-revoked-01
EXPO_PUBLIC_DEVICE_ID=seed-device-enrollment-01

# Notes :
# - Ces variables sont lues via process.env (défauts hardcodés dans src/api/client.ts
#   si absentes). Sur React Native CLI, préférez un outil d’injection d’env
#   (babel/react-native-config) ou gardez les défauts pour la démo seed.
# - Après `npm install react-native-keychain`, rebuild natif iOS/Android requis
#   (pod install / gradle) pour la persistance session.
